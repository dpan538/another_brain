**/.DS_Store
__pycache__/
**/__pycache__/
*.pyc
.env
.env.*
.vercel/
/tmp/

# Local memory, training runs, and generated evaluation artifacts are private
# runtime outputs. They can be rebuilt locally and should not be pushed to a
# public repository.
artifacts/**
!artifacts/.gitkeep

# Raw identity interviews and unredacted personal/background cards are local-only
# inputs. Public Identity Pack files live in identity_pack/ and must be redacted
# templates or safe seed cards.
private/
datasets/private/
identity_pack/private/

# Local model weights and converted artifacts are intentionally not tracked.
models/*
!models/manifest.json
!models/README.md

# R25C local static LLM intake areas may hold reviewed-but-uncommitted model
# artifacts. Real weights stay ignored unless a later patch explicitly admits
# them through the static manifest and approval gates.
static_llm/inbox/*.safetensors
static_llm/inbox/**/*.safetensors
static_llm/inbox/*.gguf
static_llm/inbox/**/*.gguf
static_llm/inbox/*.bin
static_llm/inbox/**/*.bin
static_llm/inbox/*.pt
static_llm/inbox/**/*.pt
static_llm/inbox/*.pth
static_llm/inbox/**/*.pth
static_llm/inbox/*.onnx
static_llm/inbox/**/*.onnx
static_llm/inbox/*.mlmodel
static_llm/inbox/**/*.mlmodel
static_llm/inbox/*.mlpackage
static_llm/inbox/**/*.mlpackage
static_llm/inbox/*.ckpt
static_llm/inbox/**/*.ckpt
static_llm/models_staging/*.safetensors
static_llm/models_staging/**/*.safetensors
static_llm/models_staging/*.gguf
static_llm/models_staging/**/*.gguf
static_llm/models_staging/*.bin
static_llm/models_staging/**/*.bin
static_llm/models_staging/*.pt
static_llm/models_staging/**/*.pt
static_llm/models_staging/*.pth
static_llm/models_staging/**/*.pth
static_llm/models_staging/*.onnx
static_llm/models_staging/**/*.onnx
static_llm/models_staging/*.mlmodel
static_llm/models_staging/**/*.mlmodel
static_llm/models_staging/*.mlpackage
static_llm/models_staging/**/*.mlpackage
static_llm/models_staging/*.ckpt
static_llm/models_staging/**/*.ckpt

# Runtime-only links and vendored WebLLM experiments are not used by the public
# tiny-router Web SLM path.
web/models
web/vendor/

# Private generated memory payload. The public app ships without personal
# memory cards; local builds can regenerate this file when needed.
web/brain_pack.js
