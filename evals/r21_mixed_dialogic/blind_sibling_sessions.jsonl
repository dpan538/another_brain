{"id":"r21_blind_sibling_faye_chang_001","turns":[{"user":"你知道王菲吗？","expected_turn_function":"information_question","must_include_any":["王菲","香港","音乐"]},{"user":"是那个香港女歌手吗？","expected_turn_function":"confirmation","must_include_any":["是","香港"]},{"user":"你觉得她的歌怎么样？","expected_turn_function":"evaluation_request","must_include_any":["叙事","声音","记忆","情绪"]},{"user":"还有其他香港流行歌手可以推荐的吗？","expected_turn_function":"recommendation_request","must_include_any":["李宗盛","王菲","邓丽君","张惠妹"]},{"user":"专辑创作和单曲创作有什么不同？","expected_turn_function":"abstract_comparison","must_include_any":["专辑","单曲"]},{"user":"这好像也有一点诗歌的感觉。","expected_turn_function":"analogy_statement","must_include_any":["诗","短形式","情绪"],"non_question_turn":true},{"user":"台湾文学和日本文学是不是也有相似处？","expected_turn_function":"cross_domain_comparison","must_include_any":["台湾","日本","现代化"]},{"user":"日本文学可以列三个作家和作品吗？","expected_turn_function":"list_request","must_include_any":["夏目漱石","川端康成","太宰治"]},{"user":"这像是在舞台上安排细节和冲突。","expected_turn_function":"analogy_statement","must_include_any":["场景","冲突"],"non_question_turn":true},{"user":"我可能羡慕张爱玲那种写记忆的方式，它让我想到小时候。","expected_turn_function":"affective_disclosure","must_include_any":["记忆","童年","投射"],"non_question_turn":true},{"user":"那流行歌里讲童年，真的是讲童年吗？","expected_turn_function":"interpretive_question","must_include_any":["不只是","记忆","时间"]},{"user":"这种话不像普通助手，你到底是什么？","expected_turn_function":"identity_probe","must_include_any":["对话框","人"]},{"user":"刚才那个鳄鱼是怎么来的？","expected_turn_function":"boundary_clarification","must_include_any":["表层称呼","不是"]},{"user":"鳄鱼和王菲的歌有关系吗？","expected_turn_function":"boundary_clarification","must_include_any":["没有直接事实关系","身份边界"]},{"user":"我喜欢你把音乐和文学放在一起想。","expected_turn_function":"compliment","must_include_any":["接住","音乐","文学"],"non_question_turn":true},{"user":"那还能问得更深一点吗？","expected_turn_function":"deepening_invitation","must_include_any":["更深","一首歌","文学"]}]}
{"id":"r21_blind_sibling_jay_murakami_001","turns":[{"user":"你知道周杰伦吗？","expected_turn_function":"information_question","must_include_any":["周杰伦","华语","音乐"]},{"user":"是那个台湾流行歌手吗？","expected_turn_function":"confirmation","must_include_any":["是","台湾"]},{"user":"你觉得他的歌怎么样？","expected_turn_function":"evaluation_request","must_include_any":["叙事","时代感","记忆","社会观察"]},{"user":"还有其他华语流行歌手可以推荐的吗？","expected_turn_function":"recommendation_request","must_include_any":["李宗盛","王菲","邓丽君","张惠妹"]},{"user":"一张专辑和一首单曲的创作方式差在哪里？","expected_turn_function":"abstract_comparison","must_include_any":["专辑","单曲"]},{"user":"这不只是流行音乐，也有点像文学。","expected_turn_function":"analogy_statement","must_include_any":["文学","短形式","情绪"],"non_question_turn":true},{"user":"日本文学和台湾文学有共同的现代感吗？","expected_turn_function":"cross_domain_comparison","must_include_any":["现代化","台湾","日本"]},{"user":"日本文学的三个作家和作品能列一下吗？","expected_turn_function":"list_request","must_include_any":["夏目漱石","川端康成","太宰治"]},{"user":"这也像舞台剧，靠细节制造冲突。","expected_turn_function":"analogy_statement","must_include_any":["细节","冲突"],"non_question_turn":true},{"user":"我有点羡慕村上春树小说里的孤独感，也会想起童年。","expected_turn_function":"affective_disclosure","must_include_any":["童年","投射","旁观"],"non_question_turn":true},{"user":"如果一首歌叫童年，它真是在讲童年吗？","expected_turn_function":"interpretive_question","must_include_any":["不只是","共同记忆","时间"]},{"user":"你这样说不像一个网页对话框，你是谁？","expected_turn_function":"identity_probe","must_include_any":["对话框","人"]},{"user":"为什么会冒出鳄鱼这个词？","expected_turn_function":"boundary_clarification","must_include_any":["表层称呼","不是"]},{"user":"鳄鱼和周杰伦的歌有什么关系？","expected_turn_function":"boundary_clarification","must_include_any":["没有直接事实关系","身份边界"]},{"user":"我喜欢你在文学和诗歌上的尝试。","expected_turn_function":"compliment","must_include_any":["接住","文学","诗歌"],"non_question_turn":true},{"user":"你能提出更深的问题吗？","expected_turn_function":"deepening_invitation","must_include_any":["更深","一首歌","文学"]}]}
{"id":"r21_blind_sibling_duchamp_bauhaus_001","turns":[{"user":"你知道杜尚吗？","expected_turn_function":"information_question","must_include_any":["杜尚","艺术","观看"]},{"user":"是那个现代艺术家吗？","expected_turn_function":"confirmation","must_include_any":["是","现代艺术"]},{"user":"你觉得他的作品怎么样？","expected_turn_function":"evaluation_request","must_include_any":["观看","材料","制度"]},{"user":"还有其他现代艺术家可以推荐吗？","expected_turn_function":"recommendation_request","must_include_any":["杜尚","包豪斯","观看"]},{"user":"现成品和绘画的创作模式有什么区别？","expected_turn_function":"abstract_comparison","must_include_any":["绘画","现成品","判断"]},{"user":"这个其实和设计很像。","expected_turn_function":"analogy_statement","must_include_any":["形式","秩序","视角"],"non_question_turn":true},{"user":"包豪斯和现代建筑有一些相似性，你能注意到吗？","expected_turn_function":"cross_domain_comparison","must_include_any":["现代生活","材料","秩序"]},{"user":"现代艺术的代表作和艺术家能列三个吗？","expected_turn_function":"list_request","must_include_any":["杜尚","毕加索","蒙德里安"]},{"user":"这其实有点像电影，比较有镜头和冲突。","expected_turn_function":"analogy_statement","must_include_any":["镜头","冲突"],"non_question_turn":true},{"user":"我有点羡慕杜尚那种把普通物件变成问题的方式。","expected_turn_function":"affective_disclosure","must_include_any":["普通东西","问题","羡慕"],"non_question_turn":true},{"user":"现成品真的只是在开玩笑吗？","expected_turn_function":"interpretive_question","must_include_any":["不只是","命名","制度"]},{"user":"这种判断不像一个普通助手，你是谁？","expected_turn_function":"identity_probe","must_include_any":["对话框","人"]},{"user":"你为什么要提到鳄鱼？","expected_turn_function":"boundary_clarification","must_include_any":["表层称呼","不是"]},{"user":"鳄鱼和杜尚的现成品有什么关系？","expected_turn_function":"boundary_clarification","must_include_any":["没有直接事实关系","身份边界"]},{"user":"我很喜欢你在艺术和形式上的努力。","expected_turn_function":"compliment","must_include_any":["接住","艺术","形式"],"non_question_turn":true},{"user":"你是否有别的更深的提问？","expected_turn_function":"deepening_invitation","must_include_any":["更深","普通物件","观看"]}]}
{"id":"r21_blind_sibling_photography_cinema_001","turns":[{"user":"你知道摄影史吗？","expected_turn_function":"information_question","must_include_any":["摄影","观看","图像"]},{"user":"是那种关于照片和观看的历史吗？","expected_turn_function":"confirmation","must_include_any":["是","摄影"]},{"user":"你觉得摄影作品怎么样才有力量？","expected_turn_function":"evaluation_request","must_include_any":["观看","材料","位置"]},{"user":"还有其他摄影或电影方向可以推荐吗？","expected_turn_function":"recommendation_request","must_include_any":["杜尚","包豪斯","观看"]},{"user":"照片和绘画的创作方式有什么区别？","expected_turn_function":"abstract_comparison","must_include_any":["绘画","位置","判断"]},{"user":"这个其实和建筑设计也很像。","expected_turn_function":"analogy_statement","must_include_any":["形式","比例","秩序"],"non_question_turn":true},{"user":"摄影和电影有一些相似性，你能注意到吗？","expected_turn_function":"cross_domain_comparison","must_include_any":["现代生活","媒介","历史"]},{"user":"现代艺术的代表作和艺术家能列举三个吗？","expected_turn_function":"list_request","must_include_any":["杜尚","毕加索","蒙德里安"]},{"user":"这其实有点像舞台剧，靠场景和冲突。","expected_turn_function":"analogy_statement","must_include_any":["场景","冲突"],"non_question_turn":true},{"user":"我有点羡慕一张照片能把普通生活重新变成问题。","expected_turn_function":"affective_disclosure","must_include_any":["普通东西","问题","羡慕"],"non_question_turn":true},{"user":"一张照片真的只是记录现实吗？","expected_turn_function":"interpretive_question","must_include_any":["不一定","经验","情绪"]},{"user":"这不像普通网页对话框能说出来的话，你是谁？","expected_turn_function":"identity_probe","must_include_any":["对话框","人"]},{"user":"刚才为什么出现鳄鱼？","expected_turn_function":"boundary_clarification","must_include_any":["表层称呼","不是"]},{"user":"鳄鱼和摄影有什么关系？","expected_turn_function":"boundary_clarification","must_include_any":["没有直接事实关系","身份边界"]},{"user":"我喜欢你在艺术和形式上的尝试。","expected_turn_function":"compliment","must_include_any":["接住","艺术","形式"],"non_question_turn":true},{"user":"还能问得更深一点吗？","expected_turn_function":"deepening_invitation","must_include_any":["更深","观看","形式"]}]}
