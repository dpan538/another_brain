  "title": "Vercel 静态部署案",
  "topic": "部署",
  "facts": [
    {
      "id": "f01",
      "kind": "fact",
      "text": "Vercel 对该项目只负责静态托管。",
      "tags": [
        "部署"
      ]
    },
    {
      "id": "f02",
      "kind": "fact",
      "text": "vercel.json 的 outputDirectory 是 web。",
      "tags": [
        "部署"
      ]
    },
    {
      "id": "f03",
      "kind": "fact",
      "text": "Vercel build command 是 npm run check:release。",
      "tags": [
        "部署"
      ]
    },
    {
      "id": "f04",
      "kind": "fact",
      "text": "check:release 不生成私有 artifact。",
      "tags": [
        "部署"
      ]
    },
    {
      "id": "f05",
      "kind": "fact",
      "text": ".vercelignore 排除 artifacts/**、web/brain_pack.js、web/models 和 web/vendor。",
      "tags": [
        "部署"
      ]
    },
    {
      "id": "f06",
      "kind": "fact",
      "text": "大模型不应放入 Vercel Functions 或 Edge Runtime。",
      "tags": [
        "部署"
      ]
    },
    {
      "id": "f07",
      "kind": "fact",
      "text": "训练和 artifact 生成在本地完成。",
      "tags": [
        "部署"
      ]
    },
    {
      "id": "f08",
      "kind": "fact",
      "text": "上线产物只包含压缩后的公开 runtime artifact。",
      "tags": [
        "部署"
      ]
    }
  ],
