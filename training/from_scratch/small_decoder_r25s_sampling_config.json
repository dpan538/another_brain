{
  "run_id": "r25s_data_first_balanced_192",
  "variant_id": "r25s_data_first_balanced_192",
  "training_allowed_by_default": false,
  "requires_fresh_approval": true,
  "product_model": false,
  "release_checkpoint": false,
  "commit_weights_allowed": false,
  "train_source": "training/llm_corpus/r25l_train.jsonl",
  "dev_source": "training/llm_corpus/r25l_dev.jsonl",
  "heldout_source": "training/llm_corpus/r25l_heldout.jsonl",
