{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "From-Scratch Browser Decoder Architecture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "architecture_id",
    "model_type",
    "tokenizer_id",
    "vocab_size_target",
    "context_length_target",
    "hidden_size_options",
    "layer_count_options",
    "attention_heads_options",
    "intermediate_size_options",
    "activation",
    "normalization",
    "positional_encoding",
    "quantization_target",
    "expected_parameter_ranges",
    "expected_static_asset_ranges",
    "expected_profile_fit",
    "browser_backend_target",
    "notes"
  ],
  "properties": {
    "architecture_id": { "type": "string", "minLength": 1 },
    "model_type": { "type": "string", "enum": ["decoder_only_transformer"] },
    "tokenizer_id": { "type": "string", "minLength": 1 },
    "vocab_size_target": { "type": "array", "items": { "type": "integer", "minimum": 1 } },
    "context_length_target": { "type": "array", "items": { "type": "integer", "minimum": 1 } },
    "hidden_size_options": { "type": "array", "items": { "type": "integer", "minimum": 1 } },
    "layer_count_options": { "type": "array", "items": { "type": "integer", "minimum": 1 } },
    "attention_heads_options": { "type": "array", "items": { "type": "integer", "minimum": 1 } },
    "intermediate_size_options": { "type": "array", "items": { "type": "integer", "minimum": 1 } },
    "activation": { "type": "string", "minLength": 1 },
    "normalization": { "type": "string", "minLength": 1 },
    "positional_encoding": { "type": "string", "minLength": 1 },
    "quantization_target": { "type": "string", "minLength": 1 },
    "expected_parameter_ranges": { "type": "array", "items": { "type": "string" } },
    "expected_static_asset_ranges": { "type": "array", "items": { "type": "string" } },
    "expected_profile_fit": { "type": "array", "items": { "type": "string" } },
    "browser_backend_target": { "type": "string", "minLength": 1 },
    "notes": { "type": "string" }
  }
}
